{
  "name": "accounting-backend",
  "version": "1.0.0",
  "description": "Accounting System Backend API",
  "main": "app.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npx prisma migrate deploy",
    "build:local": "tsc && prisma generate && npx prisma migrate deploy",
    "prisma:generate": "echo 'Skipping server-side generation. Using pre-generated client.'",
    "prisma:generate:local": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.8.4",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
